datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id         Int      @id @default(autoincrement()) 
  email      String   @unique @db.VarChar(255)
  age        Int
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) // Prisma stores this in UTC automatically
}