# ═══════════════════════════════════════════
#  Java Project .gitignore
# ═══════════════════════════════════════════

# ── Compiled class files ──
*.class
out/
bin/
build/
target/

# ── Package files ──
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# ── Log files ──
*.log

# ── IDE files ──
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse
.classpath
.project
.settings/

# VS Code
.vscode/

# NetBeans
nbproject/
nbbuild/
nbdist/

# ── OS generated files ──
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Temporary files ──
*.tmp
*.bak
*.swp
*~

# ── Extracted text (from PDF processing) ──
extracted_text.txt
