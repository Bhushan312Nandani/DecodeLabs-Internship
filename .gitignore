**/*.pyo
.venv/
**/.venv/
*.egg-info/

# --- Node.js ---
**/node_modules/
**/package-lock.json

# --- Java artifacts ---
**/*.class
**/target/
**/out/

# --- IDE & Editor ---
.vscode/
.idea/
*.suo
*.user

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Build & Cache ---
**/.pytest_cache/
**/build/
**/cdk.out/
**/.git/

# --- Logs & temp ---
**/*.log
**/*.crdownload
**/*.bin
*.tmp

# --- PDF files (large resources) ---
**/*.pdf

