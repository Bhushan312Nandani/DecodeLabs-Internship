{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "PassRoleToServices",
            "Effect": "Allow",
            "Action": "iam:PassRole",
            "Resource": "arn:aws:iam::<YOUR_ACCOUNT_ID>:role/*",
            "Condition": {
                "StringEquals": {
                    "iam:PassedToService": ["lambda.amazonaws.com", "cloudformation.amazonaws.com"]
                }
            }
        }
    ]
}